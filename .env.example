# Copy this to .env and fill in your Alpaca paper trading credentials.
# Never commit the actual .env file.

API_KEY=your_heinrich_api_key
API_SECRET=your_heinrich_api_secret

API_KEY_VALYA=your_valya_api_key
API_SECRET_VALYA=your_valya_api_secret

API_KEY_OUTLIERS=your_outliers_api_key
API_SECRET_OUTLIERS=your_outliers_api_secret

# Optional — defaults to 8080
PORT=8080